<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#15131C">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Cabeçalho -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/iv_voltar_treinos"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meus Treinos"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <!-- Filtros (Pills) -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="24dp">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Todos"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_pill_green"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Força"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_pill_dark"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cardio"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_pill_dark"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Flexibilidade"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_pill_dark" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Título da Lista -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Treinos da Semana"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver histórico →"
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>

        <!-- RECYCLER VIEW AQUI -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_treinos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="80dp"/>

    </LinearLayout>

    <!-- Botão Adicionar Fixo no Fundo -->
    <Button
        android:id="@+id/btn_adicionar_treino"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="⊕ Adicionar Novo Treino"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:background="@drawable/bg_btn_green_outline"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        app:backgroundTint="@null"/>

</RelativeLayout>
