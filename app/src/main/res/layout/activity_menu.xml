<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#80000000">

    <ScrollView
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="#15131C">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Botão Voltar -->
        <ImageView
            android:id="@+id/iv_voltar_menu"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp" />

        <!-- Seção Perfil -->
        <LinearLayout
            android:id="@+id/ll_editar_perfil_menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="48dp">

            <View
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_circle_profile" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/tv_nome_usuario_menu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vitor"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Editar Perfil"
                        android:textColor="#4CAF50"
                        android:textSize="14sp" />
                        
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_edit_green"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Itens do Menu -->
        <!-- Treinos -->
        <LinearLayout
            android:id="@+id/ll_treinos_menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_menu"
                android:padding="8dp"
                android:src="@drawable/ic_menu_treinos"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TREINOS"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- Meus Arquivos -->
        <LinearLayout
            android:id="@+id/ll_meus_arquivos_menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_menu"
                android:padding="8dp"
                android:src="@drawable/ic_menu_meus_arquivos"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MEUS ARQUIVOS"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- Feedbacks -->
        <LinearLayout
            android:id="@+id/ll_feedbacks_menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_menu"
                android:padding="8dp"
                android:src="@drawable/ic_menu_feedbacks"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FEEDBACKS"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- Galeria de Treinos -->
        <LinearLayout
            android:id="@+id/ll_galeria_menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_menu"
                android:padding="8dp"
                android:src="@drawable/ic_menu_galeria_treinos"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GALERIA DE TREINOS"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- PRO Banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pro_banner"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FitConnect PRO"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acesse estatísticas avançadas e planos exclusivos."
                android:textColor="#A0A0A0"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ATUALIZAR AGORA"
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Botão Sair -->
        <Button
            android:id="@+id/btn_sair_menu"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Sair"
            android:textColor="#D32F2F"
            android:background="@drawable/bg_btn_logout"
            android:layout_marginBottom="16dp"
            app:backgroundTint="@null"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

        <!-- Versão -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VERSÃO 2.4.0"
            android:textColor="#A0A0A0"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
    </ScrollView>

    <!-- Espaço da direita que vai mostrar a tela anterior -->
    <View
        android:id="@+id/v_fechar_menu"
        android:layout_width="70dp"
        android:layout_height="match_parent"
        android:background="@android:color/transparent" />

</LinearLayout>
