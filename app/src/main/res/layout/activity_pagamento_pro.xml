<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fit_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1C1A24"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/iv_voltar_pagamento_pro"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:padding="4dp"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="FitConnect Pro"
                android:textColor="@color/fit_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Hero: Plano Pro -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pro_banner"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plano Pro"
                        android:textColor="@color/fit_text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Desbloqueie todo o potencial do FitConnect"
                        android:textColor="@color/fit_text_secondary"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R$ 19,90"
                            android:textColor="@color/fit_primary_green"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginBottom="4dp"
                            android:text="/mês"
                            android:textColor="@color/fit_text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Benefícios -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="BENEFÍCIOS INCLUSOS"
                    android:textColor="@color/fit_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_card_dark"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓" android:textColor="#4CAF50" android:textSize="16sp" android:textStyle="bold"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Treinos ilimitados" android:textColor="@color/fit_text_primary" android:textSize="15sp" android:layout_marginStart="12dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓" android:textColor="#4CAF50" android:textSize="16sp" android:textStyle="bold"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Estatísticas avançadas" android:textColor="@color/fit_text_primary" android:textSize="15sp" android:layout_marginStart="12dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓" android:textColor="#4CAF50" android:textSize="16sp" android:textStyle="bold"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Histórico completo" android:textColor="@color/fit_text_primary" android:textSize="15sp" android:layout_marginStart="12dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓" android:textColor="#4CAF50" android:textSize="16sp" android:textStyle="bold"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Evolução mensal" android:textColor="@color/fit_text_primary" android:textSize="15sp" android:layout_marginStart="12dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓" android:textColor="#4CAF50" android:textSize="16sp" android:textStyle="bold"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Acompanhamento do personal" android:textColor="@color/fit_text_primary" android:textSize="15sp" android:layout_marginStart="12dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓" android:textColor="#4CAF50" android:textSize="16sp" android:textStyle="bold"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Feedbacks avançados" android:textColor="@color/fit_text_primary" android:textSize="15sp" android:layout_marginStart="12dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓" android:textColor="#4CAF50" android:textSize="16sp" android:textStyle="bold"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Relatórios de desempenho" android:textColor="@color/fit_text_primary" android:textSize="15sp" android:layout_marginStart="12dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Forma de pagamento -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="FORMA DE PAGAMENTO"
                    android:textColor="@color/fit_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rg_pagamento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_card_dark"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <RadioButton
                        android:id="@+id/rb_cartao_pagamento_pro"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:buttonTint="@color/fit_primary_green"
                        android:checked="true"
                        android:text="Cartão de crédito"
                        android:textColor="@color/fit_text_primary"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/rb_pix_pagamento_pro"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:buttonTint="@color/fit_primary_green"
                        android:text="Pix"
                        android:textColor="@color/fit_text_primary"
                        android:textSize="14sp" />
                </RadioGroup>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="Pagamento 100% seguro e simulado para demonstração"
                    android:textColor="@color/fit_text_secondary"
                    android:textSize="11sp" />

            </LinearLayout>
        </ScrollView>

        <!-- Barra de confirmação -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1C1A24"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <ProgressBar
                android:id="@+id/pb_loading_pagamento"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                android:indeterminateTint="@color/fit_primary_green" />

            <Button
                android:id="@+id/btn_confirmar_pagamento_pro"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_btn_green"
                android:text="CONFIRMAR ASSINATURA"
                android:textColor="@color/fit_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>