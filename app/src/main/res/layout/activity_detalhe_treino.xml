<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#15131C">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Cabeçalho -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/iv_voltar_detalhe"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Visão Geral"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TREINO A"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tv_titulo_detalhe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pernas e Glúteos"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="28sp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏱ 60 min  •  6 Exercícios"
            android:textColor="#A0A0A0"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hipertrofia"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_pill_green"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Intermediário"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_pill_dark" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Exercícios"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- RECYCLER VIEW AQUI -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_exercicios_detalhe"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="80dp"/>

    </LinearLayout>

    <Button
        android:id="@+id/btn_iniciar_treino"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="▶ Iniciar Treino"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:background="@drawable/bg_btn_green"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        app:backgroundTint="@null"/>

</RelativeLayout>
