<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#15131C">

    <!-- Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1C1A24"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/iv_voltar_galeria"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:padding="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Galeria de Exercícios"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- Busca -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_search_input"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="10dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_search" />

        <EditText
            android:id="@+id/et_busca_galeria"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:hint="Buscar exercícios..."
            android:textColorHint="#555555"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="@android:color/transparent"
            android:paddingStart="10dp"
            android:inputType="text" />

    </LinearLayout>

    <!-- Filtros de categoria -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView android:id="@+id/cat_todos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Todos" android:textColor="#FFFFFF" android:textSize="13sp" android:background="@drawable/bg_pill_green" android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/cat_peito" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Peito" android:textColor="#A0A0A0" android:textSize="13sp" android:background="@drawable/bg_pill_dark" android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/cat_costas" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Costas" android:textColor="#A0A0A0" android:textSize="13sp" android:background="@drawable/bg_pill_dark" android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/cat_pernas" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pernas" android:textColor="#A0A0A0" android:textSize="13sp" android:background="@drawable/bg_pill_dark" android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/cat_biceps" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bíceps" android:textColor="#A0A0A0" android:textSize="13sp" android:background="@drawable/bg_pill_dark" android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/cat_cardio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cardio" android:textColor="#A0A0A0" android:textSize="13sp" android:background="@drawable/bg_pill_dark" android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/cat_ombros" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ombros" android:textColor="#A0A0A0" android:textSize="13sp" android:background="@drawable/bg_pill_dark" android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/cat_triceps" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tríceps" android:textColor="#A0A0A0" android:textSize="13sp" android:background="@drawable/bg_pill_dark" android:clickable="true" android:focusable="true"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Header da lista -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lista de Exercícios"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_ver_filtros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="Ver filtros"
            android:textColor="#4CAF50"
            android:textSize="13sp" />

    </RelativeLayout>

    <!-- Lista de exercícios -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_exercicios_galeria"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#1C1A24"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:weightSum="4"
        android:paddingTop="8dp">

        <LinearLayout android:id="@+id/nav_inicio" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_home" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="INÍCIO" android:textColor="#A0A0A0" android:textSize="10sp" android:layout_marginTop="4dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/nav_galeria" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_gallery" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GALERIA" android:textColor="#4CAF50" android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/nav_ajuda" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_help" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AJUDA" android:textColor="#A0A0A0" android:textSize="10sp" android:layout_marginTop="4dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/nav_menu" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_menu_list" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MENU" android:textColor="#A0A0A0" android:textSize="10sp" android:layout_marginTop="4dp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>