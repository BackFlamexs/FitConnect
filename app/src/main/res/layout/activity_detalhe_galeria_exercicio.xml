<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#15131C"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/iv_voltar_detalhe_galeria"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detalhe do Exercício"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_centerInParent="true" />

        </RelativeLayout>

        <!-- GIF / Thumbnail grande -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="#1E1B2B"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/iv_gif_detalhe"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <!-- Ícone padrão quando sem GIF -->
            <LinearLayout
                android:id="@+id/layout_sem_gif"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_fitness_topic"
                    android:alpha="0.4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sem prévia disponível"
                    android:textColor="#666666"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

        </FrameLayout>

        <!-- Informações do exercício -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- Nome -->
            <TextView
                android:id="@+id/tv_nome_detalhe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Supino Reto"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Tags: categoria + dificuldade -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tv_categoria_detalhe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Peito"
                    android:textColor="#4CAF50"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_pill_dark"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tv_dificuldade_detalhe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Intermediário"
                    android:textColor="#A0A0A0"
                    android:textSize="12sp"
                    android:background="@drawable/bg_pill_dark" />

            </LinearLayout>

            <!-- Equipamento -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Equipamento: "
                    android:textColor="#A0A0A0"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_equipamento_detalhe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Barra"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Divisor -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2A2A3A"
                android:layout_marginBottom="20dp" />

            <!-- Instruções -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Como executar"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tv_instrucoes_detalhe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sem instruções disponíveis."
                android:textColor="#A0A0A0"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="32dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>