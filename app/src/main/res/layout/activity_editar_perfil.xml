<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#15131C">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Cabeçalho -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp">

            <ImageView
                android:id="@+id/iv_voltar_editar_perfil"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar Perfil"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <!-- Mensagem de Sucesso (invisível por padrão, ficará visível ao salvar) -->
        <LinearLayout
            android:id="@+id/ll_sucesso_salvar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_cartao_home"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:layout_marginBottom="32dp"
            android:visibility="gone">
            
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_check_green"
                android:background="@drawable/bg_circle_profile"
                android:padding="4dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sucesso!"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Perfil salvo com sucesso!"
                    android:textColor="#A0A0A0"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Foto de Perfil Central -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="48dp">
            
            <RelativeLayout
                android:layout_width="100dp"
                android:layout_height="100dp">
                
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_circle_empty"/>
                    
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_edit_green"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_circle_profile"
                    android:padding="6dp"/>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alterar foto de perfil"
                android:textColor="#4CAF50"
                android:textSize="14sp"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- Formulário -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOME COMPLETO"
            android:textColor="#A0A0A0"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/et_nome_editar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input_dark"
            android:paddingHorizontal="16dp"
            android:textColor="#FFFFFF"
            android:hint="Vitor Gomes"
            android:textColorHint="#A0A0A0"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMAIL"
            android:textColor="#A0A0A0"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/et_email_editar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input_dark"
            android:paddingHorizontal="16dp"
            android:textColor="#FFFFFF"
            android:hint="vitor.gomes@gmail.com"
            android:textColorHint="#A0A0A0"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SENHA"
            android:textColor="#A0A0A0"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/et_senha_editar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input_dark"
            android:paddingHorizontal="16dp"
            android:textColor="#FFFFFF"
            android:inputType="textPassword"
            android:hint="********"
            android:textColorHint="#A0A0A0"
            android:layout_marginBottom="48dp"/>

        <!-- Informações Físicas -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Informações Físicas"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Utilizado para cálculo de calorias"
            android:textColor="#A0A0A0"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PESO (KG)"
                    android:textColor="#A0A0A0"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/et_peso_editar"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_input_dark"
                    android:paddingHorizontal="16dp"
                    android:textColor="#FFFFFF"
                    android:inputType="numberDecimal"
                    android:hint="62.5"
                    android:textColorHint="#A0A0A0"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ALTURA (CM)"
                    android:textColor="#A0A0A0"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/et_altura_editar"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_input_dark"
                    android:paddingHorizontal="16dp"
                    android:textColor="#FFFFFF"
                    android:inputType="number"
                    android:hint="168"
                    android:textColorHint="#A0A0A0"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Botão Salvar -->
        <Button
            android:id="@+id/btn_salvar_perfil"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Salvar"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_green"
            app:backgroundTint="@null"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

    </LinearLayout>
</ScrollView>
