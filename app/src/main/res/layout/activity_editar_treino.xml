<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#15131C">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Cabeçalho -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp">

            <ImageView
                android:id="@+id/iv_voltar_editar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar Treino"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <!-- Botão Excluir -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_dark"
            android:padding="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_delete_red"
                android:layout_marginEnd="16dp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Excluir Treino"
                    android:textColor="#D32F2F"
                    android:textStyle="bold"
                    android:textSize="16sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Esta ação não pode ser desfeita"
                    android:textColor="#D32F2F"
                    android:textSize="10sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Nome do Treino -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nome do Treino"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/et_nome_treino_editar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input_dark"
            android:text="Peito e Triceps"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp"/>

        <!-- Dia da Semana (Simulado) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dia da Semana"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp"
            android:weightSum="7">
            <!-- Simulação de bolinhas de dias, S está verde -->
            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:background="@drawable/bg_circle_empty" android:text="D" android:gravity="center" android:textColor="#A0A0A0" android:layout_marginEnd="4dp"/>
            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:background="@drawable/bg_circle_profile" android:text="S" android:gravity="center" android:textColor="#FFFFFF" android:layout_marginEnd="4dp"/>
            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:background="@drawable/bg_circle_empty" android:text="T" android:gravity="center" android:textColor="#A0A0A0" android:layout_marginEnd="4dp"/>
            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:background="@drawable/bg_circle_empty" android:text="Q" android:gravity="center" android:textColor="#A0A0A0" android:layout_marginEnd="4dp"/>
            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:background="@drawable/bg_circle_empty" android:text="Q" android:gravity="center" android:textColor="#A0A0A0" android:layout_marginEnd="4dp"/>
            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:background="@drawable/bg_circle_empty" android:text="S" android:gravity="center" android:textColor="#A0A0A0" android:layout_marginEnd="4dp"/>
            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:background="@drawable/bg_circle_empty" android:text="S" android:gravity="center" android:textColor="#A0A0A0"/>
        </LinearLayout>

        <!-- Header Exercícios -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Exercícios (4)"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ ADICIONAR"
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>

        <!-- Lista Estática Simples para Editar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_dark"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <View android:layout_width="24dp" android:layout_height="24dp" android:background="#1C1A24" android:layout_marginEnd="16dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Supino Reto" android:textColor="#FFFFFF" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4 séries • 10 reps • 30kg" android:textColor="#A0A0A0" android:textSize="12sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⊖" android:textColor="#A0A0A0" android:textSize="20sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_dark"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">
            <View android:layout_width="24dp" android:layout_height="24dp" android:background="#1C1A24" android:layout_marginEnd="16dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Triceps Corda" android:textColor="#FFFFFF" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4 séries • 12 reps • 35kg" android:textColor="#A0A0A0" android:textSize="12sp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⊖" android:textColor="#A0A0A0" android:textSize="20sp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_salvar_alteracoes"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Salvar Alterações"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_green"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:backgroundTint="@null"/>

    </LinearLayout>
</ScrollView>
