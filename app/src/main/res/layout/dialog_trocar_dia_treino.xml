<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_dark"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_titulo_troca_dia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dia já usado"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_mensagem_troca_dia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#A0A0A0"
        android:textSize="14sp"
        android:lineSpacingExtra="3dp"
        android:layout_marginBottom="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_cancelar_troca_dia"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_topic_card"
            android:gravity="center"
            android:text="Cancelar"
            android:textColor="#A0A0A0"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/btn_confirmar_troca_dia"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_green"
            android:gravity="center"
            android:text="Trocar dias"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

    </LinearLayout>
</LinearLayout>
