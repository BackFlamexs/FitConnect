<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#15131C">

    <!-- Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1C1A24"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/iv_voltar_feedback"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:padding="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Feedback Pós-Treino"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_cancelar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:text="Cancelar"
            android:textColor="#A0A0A0"
            android:textSize="14sp" />

    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Título -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Como foi o treino?"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_nome_treino_feedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Registre a intensidade pós-treino para acompanhar sua próxima sessão..."
                android:textColor="#A0A0A0"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="28dp" />

            <!-- Seleção de intensidade -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <!-- Leve -->
                <LinearLayout
                    android:id="@+id/card_leve"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_topic_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ic_leve"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_intensidade_leve"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tv_leve"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Leve"
                        android:textColor="#A0A0A0"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Moderado -->
                <LinearLayout
                    android:id="@+id/card_moderado"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_topic_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ic_moderado"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_intensidade_moderado"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tv_moderado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Moderado"
                        android:textColor="#A0A0A0"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Intenso -->
                <LinearLayout
                    android:id="@+id/card_intenso"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_topic_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ic_intenso"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_intensidade_intenso"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tv_intenso"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Intenso"
                        android:textColor="#A0A0A0"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Duração -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_topic_card"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_timer"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Tempo do treino"
                    android:textColor="#A0A0A0"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/et_duracao"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:hint="0"
                    android:textColorHint="#555555"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="end"
                    android:background="@android:color/transparent"
                    android:inputType="number" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" min"
                    android:textColor="#A0A0A0"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Observações -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Observações"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_topic_card"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="28dp">

                <EditText
                    android:id="@+id/et_observacoes"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:hint="Como você se sentiu? Alguma dor ou desconforto específico hoje?"
                    android:textColorHint="#555555"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:background="@android:color/transparent"
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    android:maxLines="5" />

                <TextView
                    android:id="@+id/tv_contador"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="200"
                    android:textColor="#555555"
                    android:textSize="12sp"
                    android:gravity="end"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Botão Enviar -->
            <LinearLayout
                android:id="@+id/btn_enviar_feedback"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_green"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enviar Feedback  ▶"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
